# ─── Datenbank (Docker: docker compose up -d) ───────────────────────────────
DATABASE_URL=postgresql://voicebot:voicebot@localhost:5432/voicebot

# ─── LiveKit (selbst-gehostet, --dev-Modus → feste Dev-Credentials) ──────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── LLM (Default: lokal via LM Studio, OpenAI-kompatibel) ───────────────────
# LM Studio: Server starten (Standardport 1234), Modell laden.
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-e4b

# Optional Cloud-Alternative:
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=

# ─── Embeddings (erst relevant, wenn RAG nachgerüstet wird — aktuell ungenutzt) ─
# Phase 1 nutzt Handbuch-im-Kontext + Prompt-Caching statt RAG (siehe Spec §6).
# EMBEDDING_BASE_URL=http://localhost:1234/v1
# EMBEDDING_API_KEY=lm-studio
# EMBEDDING_MODEL=nomic-embed-text

# ─── STT (Default: lokaler faster-whisper-Dienst) ────────────────────────────
STT_PROVIDER=local-whisper
STT_SERVICE_URL=http://localhost:8001
# Optional: DEEPGRAM_API_KEY=

# ─── TTS (Default: lokaler Piper-Dienst) ─────────────────────────────────────
TTS_PROVIDER=local-piper
TTS_SERVICE_URL=http://localhost:8002
# Optional: ELEVENLABS_API_KEY=
