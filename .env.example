# ─── Datenbank (Docker: docker compose up -d) ───────────────────────────────
DATABASE_URL=postgresql://voicebot:voicebot@localhost:5432/voicebot

# ─── LiveKit (selbst-gehostet, --dev-Modus → feste Dev-Credentials) ──────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── Voice-Agent (Python) ────────────────────────────────────────────────────
# URL, unter der der Agent das Web-Backend erreicht (System-Prefix + Pipeline-Config).
# Port 3000 oft belegt → Frontend meist auf 3100 (PORT=3100 pnpm dev:web).
WEB_BASE_URL=http://localhost:3100
# Ausgabe-Samplerate der TTS-Pipeline (Piper-WAV wird darauf resampled).
# TTS_SAMPLE_RATE=24000

# ─── LLM (Default: lokal via LM Studio, OpenAI-kompatibel) ───────────────────
# LM Studio: Server starten (Standardport 1234), Modell laden.
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-4-e4b

# Optional Cloud-Alternative:
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=

# ─── Embeddings (erst relevant, wenn RAG nachgerüstet wird — aktuell ungenutzt) ─
# Phase 1 nutzt Handbuch-im-Kontext + Prompt-Caching statt RAG (siehe Spec §6).
# EMBEDDING_BASE_URL=http://localhost:1234/v1
# EMBEDDING_API_KEY=lm-studio
# EMBEDDING_MODEL=nomic-embed-text

# ─── STT (Default: lokaler faster-whisper-Dienst) ────────────────────────────
STT_PROVIDER=local-whisper
STT_SERVICE_URL=http://localhost:8001
# Optional: DEEPGRAM_API_KEY=
# Whisper-Tuning (faster-whisper-Dienst):
#   CPU-only (Default):  WHISPER_MODEL=small  WHISPER_DEVICE=cpu   WHISPER_COMPUTE=int8
#   GPU (NVIDIA, CUDA):  WHISPER_MODEL=large-v3-turbo  WHISPER_DEVICE=cuda  WHISPER_COMPUTE=float16
#   GPU braucht die CUDA-Runtime-Wheels (siehe services/stt-whisper/requirements.txt):
#     pip install nvidia-cublas-cu12 nvidia-cudnn-cu12
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_BEAM=5
# Fachvokabular biasen (verhindert z.B. "Bedarf"->"Bettorf"). Pro Domäne anpassen:
# WHISPER_PROMPT=Bedarfsplaner, Standardbedarf, Artikel, Lager, Bestellung.

# ─── TTS (Default: lokaler Piper-Dienst) ─────────────────────────────────────
TTS_PROVIDER=local-piper
TTS_SERVICE_URL=http://localhost:8002
# XTTS-v2 (neural, GPU) — alternativer TTS-Dienst, pro Bot via Provider "local-xtts":
XTTS_SERVICE_URL=http://localhost:8003
# Optional: ELEVENLABS_API_KEY=
